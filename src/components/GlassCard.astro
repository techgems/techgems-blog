---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<div class="relative overflow-hidden rounded-2xl bg-white/5 backdrop-blur-xl border border-white/10 shadow-[0_8px_32px_rgba(0,0,0,0.3)] p-8">
	<h1 class="flex justify-center mb-6 sm:mb-8 text-3xl sm:text-4xl lg:text-5xl font-bold text-center text-white">
		{title}
	</h1>

	<!-- Description slot -->
	<div class="text-gray-300">
		<slot name="description" />
	</div>

	<!-- Downloads / stats slot -->
	<slot name="stats" />

	<!-- Links slot -->
	<div class="flex flex-wrap justify-center gap-3 mt-8 sm:mt-12">
		<slot name="links" />
	</div>
</div>
