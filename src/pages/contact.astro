---
import DarkLayout from "../layouts/DarkLayout.astro";

import { library, icon } from "@fortawesome/fontawesome-svg-core";
import {
  faGithubSquare,
  faSquareLinkedin,
} from "@fortawesome/free-brands-svg-icons";

library.add(faGithubSquare, faSquareLinkedin);

const linkedInIcon = icon(faSquareLinkedin);
const githubIcon = icon(faGithubSquare);
---

<DarkLayout
  title="Contact Carlos"
  description="Get in touch with Carlos for your web development needs"
  useWrapper={false}
  useBlogHead={false}
>
  <div class="relative overflow-hidden min-h-screen pt-16">
    <!-- Background blobs -->
    <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-indigo-700/30 rounded-full blur-[60px] animate-hero-blob"></div>
    <div class="absolute bottom-0 right-0 w-[550px] h-[550px] bg-cyan-600/25 rounded-full blur-[70px] animate-hero-blob animation-delay-3000"></div>
    <div class="absolute top-1/2 left-1/3 w-[400px] h-[400px] bg-teal-700/20 rounded-full blur-[60px] animate-hero-blob animation-delay-4000"></div>
    <div class="absolute top-1/4 right-1/4 w-[350px] h-[350px] bg-blue-600/20 rounded-full blur-[50px] animate-hero-blob animation-delay-2000"></div>
    <div class="absolute bottom-1/4 left-1/4 w-[450px] h-[450px] bg-sky-600/20 rounded-full blur-[65px] animate-hero-blob animation-delay-4000"></div>
    <div class="absolute top-3/4 right-1/3 w-[400px] h-[400px] bg-indigo-600/20 rounded-full blur-[55px] animate-hero-blob animation-delay-2000"></div>

    <div class="relative z-10">
      <section class="max-w-3xl mx-auto my-16 px-4 sm:px-6 lg:px-8">
        <div class="prose prose-invert">
          <h3 class="text-cyan-400 text-4xl sm:text-5xl lg:text-6xl">Get in touch</h3>
          <p class="text-gray-300">
            Whether you have a question, a project idea, or just want to say hello,
            feel free to reach out!
          </p>
          <form action="https://api.web3forms.com/submit" method="POST" class="mx-auto mt-8 sm:mt-12 max-w-xl">
            <input
              type="hidden"
              name="access_key"
              value="497918da-fe85-4207-b08d-9827ee76e82d"
            />
            <div>
              <div class="my-4">
                <label for="name" class="block text-sm/6 font-semibold text-gray-200">Name</label>
                <div class="mt-2.5">
                  <input id="name" type="text" name="name" autocomplete="given-name" required class="block w-full rounded-md bg-white/10 backdrop-blur-sm px-3.5 py-2 text-base text-gray-100 border border-white/10 placeholder:text-gray-500 focus:outline-2 focus:-outline-offset-2 focus:outline-cyan-500" />
                </div>
              </div>
              <div class="my-4">
                <label for="email" class="block text-sm/6 font-semibold text-gray-200">Email</label>
                <div class="mt-2.5">
                  <input id="email" type="email" name="email" autocomplete="email" required class="block w-full rounded-md bg-white/10 backdrop-blur-sm px-3.5 py-2 text-base text-gray-100 border border-white/10 placeholder:text-gray-500 focus:outline-2 focus:-outline-offset-2 focus:outline-cyan-500" />
                </div>
              </div>
              <div class="my-4">
                <label for="message" class="block text-sm/6 font-semibold text-gray-200">Message</label>
                <div class="mt-2.5">
                  <textarea id="message" name="message" rows="4" required class="block w-full rounded-md bg-white/10 backdrop-blur-sm px-3.5 py-2 text-base text-gray-100 border border-white/10 placeholder:text-gray-500 focus:outline-2 focus:-outline-offset-2 focus:outline-cyan-500"></textarea>
                </div>
              </div>
            </div>
            <div class="mt-8">
              <input class="cta-btn block w-full rounded-md bg-neutral-800 px-3.5 py-2.5 text-center text-sm font-semibold text-white shadow-xs cursor-pointer" type="submit" value="Let's talk" />
            </div>
          </form>
        </div>

        <div class="mt-16 prose prose-invert">
          <h3 class="text-cyan-400 text-3xl sm:text-4xl">Other Ways to Connect</h3>
          <div class="flex flex-wrap items-center gap-2 sm:gap-4">
            <a
              class="text-gray-300 hover:text-white mx-1 sm:mx-2 w-20 sm:w-24 lg:w-28 p-2 sm:p-3 block transition-colors duration-300"
              href="https://github.com/techgems"
              target="_blank"
              rel="noopener"
            >
              <Fragment set:html={githubIcon.html} />
            </a>
            <a
              class="text-cyan-400 hover:text-cyan-300 mx-1 sm:mx-2 w-20 sm:w-24 lg:w-28 p-2 sm:p-3 block transition-colors duration-300"
              href="https://www.linkedin.com/in/carlos-jimenez-61a926b7/"
              target="_blank"
              rel="noopener"
            >
              <Fragment set:html={linkedInIcon.html} />
            </a>
          </div>
        </div>
      </section>
    </div>
  </div>
</DarkLayout>
