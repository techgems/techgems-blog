---
import DarkLayout from '../layouts/DarkLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<DarkLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
		<section class="relative z-[2] overflow-hidden bg-neutral-800 text-white pb-16" style="clip-path: polygon(0 0, 100% 0, 100% calc(100% - 100px), 50% 100%, 0 calc(100% - 100px));">
			<!-- Hero background blobs (larger, darker, slower) -->
			<div class="absolute top-0 left-0 w-[500px] h-[500px] bg-indigo-700/50 rounded-full blur-[60px] animate-hero-blob"></div>
			<div class="absolute bottom-0 right-0 w-[600px] h-[600px] bg-cyan-600/40 rounded-full blur-[70px] animate-hero-blob animation-delay-3000"></div>
			<div class="absolute top-1/3 right-1/4 w-[400px] h-[400px] bg-blue-600/35 rounded-full blur-[50px] animate-hero-blob animation-delay-2000"></div>
			<div class="absolute -bottom-20 left-1/3 w-[450px] h-[450px] bg-teal-700/35 rounded-full blur-[60px] animate-hero-blob animation-delay-4000"></div>
			<div class="absolute top-1/2 -left-20 w-[350px] h-[350px] bg-sky-600/30 rounded-full blur-[55px] animate-hero-blob animation-delay-3000"></div>

			<div class="relative z-10 pt-10 pb-5 sm:py-24 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-3">
				<img src="/images/profile.png" alt="Carlos Photo" class="col-span-1 rounded-t-2xl md:rounded-l-2xl md:rounded-r-none" />
				<div class="relative col-span-2 text-3xl sm:text-4xl lg:text-5xl overflow-hidden bg-white/5 backdrop-blur-xl border border-white/10 shadow-[0_8px_32px_rgba(0,0,0,0.3)] rounded-b-2xl md:rounded-r-2xl md:rounded-l-none p-5 sm:p-8 mx-auto font-light flex flex-col justify-center">
					<!-- Animated blob shapes -->
					<div class="absolute -top-20 -left-20 w-64 h-64 bg-cyan-500/20 rounded-full blur-3xl animate-blob"></div>
					<div class="absolute -bottom-24 -right-16 w-72 h-72 bg-blue-600/20 rounded-full blur-3xl animate-blob animation-delay-2000"></div>
					<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-56 h-56 bg-cyan-700/15 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
					<div class="absolute -top-10 right-1/4 w-40 h-40 bg-sky-400/10 rounded-full blur-2xl animate-blob animation-delay-3000"></div>

					<!-- Content (above blobs) -->
					<div class="relative z-10">
						I'm <span class="text-sky-500 font-semibold">Carlos</span> - Builder of online platforms. I take your app ideas from <span class="text-sky-600 font-light">Concept</span> to <span class="text-sky-400 font-bold">Reality</span>
					</div>
					<div class="relative z-10 flex flex-wrap gap-2 justify-start mt-6 sm:mt-8">
						<span class="cta-btn bg-neutral-800 rounded-md text-base sm:text-xl lg:text-2xl font-normal text-white px-4 py-2 ">
							<a href="/contact">Let's Talk</a>
						</span>
						<span class="cta-btn bg-neutral-800 rounded-md text-base sm:text-xl lg:text-2xl font-normal text-white px-4 py-2">
							<a href="/resume">View Resume</a>
						</span>
					</div>
					</div>
				</div>
			</div>
		</section>

		<section class="relative z-[1] bg-gray-900 pb-32 pt-28 -mt-24 px-4 sm:px-6 lg:px-8" style="clip-path: polygon(0 0, 100% 0, 100% calc(100% - 100px), 50% 100%, 0 calc(100% - 100px));">
			<div class="prose-lg mx-auto max-w-7xl">
				<h2 class="text-cyan-200 font-semibold pb-4 text-4xl text-center">About Me</h2>
				<p class="mt-4 text-gray-300">
					I'm Carlos Jimenez and I'm a Software Engineer with 10+ years of experience, primarily in building applications for the education industry. I excel primarily in <span class="font-semibold">C#</span>, <span class="font-semibold">ASP.NET Core</span>, <span class="font-semibold">ASP.NET Core</span>, <span class="font-semibold">React</span> and <span class="font-semibold">Typescript</span>, but I have worked with several other stacks as needed.
				</p>
				<p class="text-gray-300">
					I have a strong background in building scalable and maintainable web applications, with a focus on delivering high-quality user experiences. Over the years, I have had the opportunity to work on a wide range of projects, from small startups to large enterprises, which has given me a deep understanding of the software development lifecycle and best practices.
					
					Migrating older systems into modern cloud-based solutions is something I have extensive experience with. I can build solid and reliable systems in AWS and Azure. I believe that good engineering is all about understanding tradeoffs and finding the best fit for a specific scenario. I have had ample experience leading teams and coordinating the efforts of both developers and designers in order to ensure a final product that is both aesthetically pleasing and functionally sound.
				</p>
				<p class="text-gray-300">
					I'm also an author of multiple open-source libraries as I have encountered challenges that would benefit from solutions not previously available.
				</p>
			</div>
		</section>

		<section class="relative z-0 overflow-hidden bg-neutral-950 -mt-24 pt-28 pb-8 px-4 sm:px-6 lg:px-8">
			<!-- Animated blob shapes (hero-style, reduced density) -->
			<div class="absolute -top-20 -left-20 w-[400px] h-[400px] bg-indigo-700/30 rounded-full blur-[60px] animate-hero-blob"></div>
			<div class="absolute -bottom-24 -right-16 w-[450px] h-[450px] bg-cyan-600/25 rounded-full blur-[70px] animate-hero-blob animation-delay-3000"></div>
			<div class="absolute top-1/2 left-1/3 w-[350px] h-[350px] bg-teal-700/20 rounded-full blur-[60px] animate-hero-blob animation-delay-4000"></div>

			<div class="relative z-10 mx-auto max-w-7xl">
			<!-- Glassmorphic card -->
			<div class="relative overflow-hidden rounded-2xl bg-white/5 backdrop-blur-xl border border-white/10 shadow-[0_8px_32px_rgba(0,0,0,0.3)] p-8 sm:p-12">

				<!-- Content (above blobs) -->
				<div class="relative z-10 prose-lg">
					<h2 class="text-cyan-200 font-semibold border-cyan-500 border-b-4 pb-4 text-4xl">Get In Touch</h2>
					<p class="mt-4 text-gray-300">
						If you're interested in working together or have any questions, feel free to contact me. 
					</p>
					<div class="mt-4 flex justify-center">
						<span class="cta-btn-outlined rounded-md text-base sm:text-xl lg:text-2xl font-normal text-white px-4 py-2 bg-white/5">
							<a class="text-white no-underline" href="/contact">Contact me</a>
						</span>
					</div>
				</div>
			</div>
			</div>
		</section>
</DarkLayout>
