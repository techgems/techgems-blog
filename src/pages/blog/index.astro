---
import DarkLayout from '../../layouts/DarkLayout.astro';
import { Image } from "astro:assets";
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const placeholderHeroImage1 = '/blog-placeholder-1.jpg';
const placeholderHeroImage2 = '/blog-placeholder-2.jpg';
const placeholderHeroImage3 = '/blog-placeholder-3.jpg';
const placeholderHeroImage4 = '/blog-placeholder-4.jpg';


const posts = (await getCollection('blog', ({ data }) => {
	return data.published === true;
})).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<DarkLayout title={SITE_TITLE} description={SITE_DESCRIPTION} useWrapper={false} useBlogHead={false}>
	<div class="relative overflow-hidden min-h-screen pt-16">
		<!-- Background blobs -->
		<div class="absolute top-0 left-0 w-[500px] h-[500px] bg-indigo-700/30 rounded-full blur-[60px] animate-hero-blob"></div>
		<div class="absolute bottom-0 right-0 w-[550px] h-[550px] bg-cyan-600/25 rounded-full blur-[70px] animate-hero-blob animation-delay-3000"></div>
		<div class="absolute top-1/2 left-1/3 w-[400px] h-[400px] bg-teal-700/20 rounded-full blur-[60px] animate-hero-blob animation-delay-4000"></div>
		<div class="absolute top-1/4 right-1/4 w-[350px] h-[350px] bg-blue-600/20 rounded-full blur-[50px] animate-hero-blob animation-delay-2000"></div>
		<div class="absolute bottom-1/4 left-1/4 w-[450px] h-[450px] bg-sky-600/20 rounded-full blur-[65px] animate-hero-blob animation-delay-4000"></div>
		<div class="absolute top-3/4 right-1/3 w-[400px] h-[400px] bg-indigo-600/20 rounded-full blur-[55px] animate-hero-blob animation-delay-2000"></div>

		<div class="relative z-10">
			<section class="mx-auto mt-8 mb-20 max-w-7xl px-4 sm:px-6 lg:px-8">
				<ul class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8 list-none m-0 p-0">
					{
						posts.map((post, index) => {
							
							let finalHeroImage = "";

							if(post.data.usePlaceholderHeroInList && !post.data.heroImage) {
								const placeholderHeroImages = [
									placeholderHeroImage1,
									placeholderHeroImage2,
									placeholderHeroImage3,
									placeholderHeroImage4,
								];
								const randomIndex = Math.floor(Math.random() * 4);
								finalHeroImage = placeholderHeroImages[randomIndex];
							}

							return (
								<li class={index === 0 ? "md:col-span-2 text-center" : ""}>
									<a href={`/blog/${post.slug}/`} class="block group">
										{ post.data.usePlaceholderHeroInList && !post.data.heroImage ? (
											<img width={720} height={360} src={finalHeroImage} alt="" class="w-full mb-2 rounded-xl transition-shadow duration-300 group-hover:shadow-[0_8px_32px_rgba(6,182,212,0.2)]" />
										) : (
											<Image src={post.data.heroImage!} alt="" class="w-full mb-2 rounded-xl transition-shadow duration-300 group-hover:shadow-[0_8px_32px_rgba(6,182,212,0.2)]" />
										)}
										<h4 class={`${index === 0 ? 'text-2xl sm:text-4xl' : 'text-xl sm:text-2xl'} text-gray-100 group-hover:text-cyan-400 transition-colors duration-200 m-0 leading-tight`}>{post.data.title}</h4>
										<p class="text-gray-400 group-hover:text-cyan-400 transition-colors duration-200 m-0">
											<FormattedDate date={post.data.date} />
										</p>
									</a>
								</li>
							);
						})
					}
				</ul>
			</section>
		</div>
	</div>
</DarkLayout>
