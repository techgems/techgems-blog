---
import DarkLayout from "../layouts/DarkLayout.astro";
import ResumeTimeline from "../components/timeline/resume-timeline.tsx";
import ResumeSkillCard from "../components/ResumeSkillCard.astro";

import ReactImg from '../images/skills/react.svg';
import TypescriptImg from '../images/skills/typescript.svg';
import JavascriptImg from '../images/skills/javascript.png';
import DotNetImg from '../images/skills/dotnet.svg';
import CSharpImg from '../images/skills/csharp.svg';

import SqlServerImg from "../images/skills/sqlserver.svg";
import PostgresImg from '../images/skills/postgres.svg';
import DynamoDbImg from '../images/skills/dynamodb.svg';

import AwsImg from '../images/skills/aws.svg';
import AzureImg from '../images/skills/azure.svg';
import CloudflareImg from '../images/skills/cloudflare.svg';
import DockerImg from '../images/skills/docker.svg';
import TailwindCssImg from '../images/skills/tailwind.svg';
import Html5Img from '../images/skills/html5.svg';
import Css3Img from '../images/skills/css3.svg';
import GitImg from '../images/skills/git.svg';
import SvelteImg from '../images/skills/svelte.svg';
---

<DarkLayout
  title="Resume"
  description="Carlos's Resume - Full Stack Developer specializing in modern web technologies."
  useWrapper={false}
  useBlogHead={false}
>
    <div class="relative overflow-hidden min-h-screen pt-16">
        <!-- Background blobs (full screen) -->
        <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-indigo-700/30 rounded-full blur-[60px] animate-hero-blob"></div>
        <div class="absolute bottom-0 right-0 w-[550px] h-[550px] bg-cyan-600/25 rounded-full blur-[70px] animate-hero-blob animation-delay-3000"></div>
        <div class="absolute top-1/2 left-1/3 w-[400px] h-[400px] bg-teal-700/20 rounded-full blur-[60px] animate-hero-blob animation-delay-4000"></div>
        <div class="absolute top-1/4 right-1/4 w-[350px] h-[350px] bg-blue-600/20 rounded-full blur-[50px] animate-hero-blob animation-delay-2000"></div>
        <div class="absolute bottom-1/4 left-1/4 w-[450px] h-[450px] bg-sky-600/20 rounded-full blur-[65px] animate-hero-blob animation-delay-4000"></div>
        <div class="absolute top-3/4 right-1/3 w-[400px] h-[400px] bg-indigo-600/20 rounded-full blur-[55px] animate-hero-blob animation-delay-2000"></div>
        <div class="absolute top-[10%] left-[60%] w-[380px] h-[380px] bg-purple-700/25 rounded-full blur-[55px] animate-hero-blob animation-delay-1000"></div>
        <div class="absolute top-[60%] right-[10%] w-[480px] h-[480px] bg-blue-700/25 rounded-full blur-[65px] animate-hero-blob animation-delay-1000"></div>
        <div class="absolute top-[15%] left-[40%] w-[350px] h-[350px] bg-teal-600/25 rounded-full blur-[50px] animate-hero-blob animation-delay-2000"></div>
        <div class="absolute top-[45%] right-[20%] w-[400px] h-[400px] bg-indigo-500/20 rounded-full blur-[55px] animate-hero-blob animation-delay-4000"></div>
        <div class="absolute top-[5%] right-[5%] w-[300px] h-[300px] bg-violet-600/20 rounded-full blur-[50px] animate-hero-blob animation-delay-3000"></div>
        <div class="absolute bottom-[10%] right-[40%] w-[380px] h-[380px] bg-cyan-500/20 rounded-full blur-[55px] animate-hero-blob animation-delay-4000"></div>

    <div class="relative z-10">
    <section class="prose max-w-7xl px-4 sm:px-6 lg:px-8 mt-12 sm:mt-16 lg:mt-20 mx-auto">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">Summary</h1>
        <p class="text-lg text-gray-300">
            I'm Carlos Jimenez. I'm a Software Engineer with over <strong class="text-white">10 years of experience</strong>. I excel primarily in <strong class="text-white">C#</strong>, <strong class="text-white">ASP.NET Core</strong>, <strong class="text-white">React</strong> and <strong class="text-white">Typescript</strong>, but I have worked with other stacks in the past, such as <strong class="text-white">NextJS</strong> and <strong class="text-white">Laravel</strong>.
        </p>
        <p class="text-lg text-gray-300">
            I have had the chance to build many projects from scratch using Cloud native architectures, as well as migrating older systems into modern cloud-based solutions. I can build solid and reliable systems in <strong class="text-white">AWS</strong> and <strong class="text-white">Azure</strong>. I believe that good engineering is all about understanding tradeoffs and finding the best fit for a specific scenario. I have had ample experience leading teams and coordinating the efforts of both developers and designers in order to ensure a final product that is both aesthetically pleasing and functionally sound.
        </p>
    </section>
    <section class="max-w-7xl px-4 sm:px-6 lg:px-8 mt-12 sm:mt-16 lg:mt-20 mx-auto">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">Skills</h1>

        <div class="mb-8">
            <h3 class="text-xl sm:text-2xl font-semibold text-gray-200 mb-6">Primary Stack</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-x-4 gap-y-8">
                <ResumeSkillCard skillName="C#" image={CSharpImg} />
                <ResumeSkillCard skillName=".NET Core" image={DotNetImg} />
                <ResumeSkillCard skillName="React.js" image={ReactImg} />
                <ResumeSkillCard skillName="TypeScript" image={TypescriptImg} />
                <ResumeSkillCard skillName="JavaScript" image={JavascriptImg} />
                <ResumeSkillCard skillName="Tailwind CSS" image={TailwindCssImg} />
            </div>
        </div>

        <div class="mt-12 mb-8">
            <h3 class="text-xl sm:text-2xl font-semibold text-gray-200 mb-6">Databases</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-x-4 gap-y-8">
                <ResumeSkillCard skillName="SQL Server" image={SqlServerImg} />
                <ResumeSkillCard skillName="PostgreSQL" image={PostgresImg} />
                <ResumeSkillCard skillName="DynamoDB" image={DynamoDbImg} />
            </div>
        </div>

        <div class="mt-12 mb-8">
            <h3 class="text-xl sm:text-2xl font-semibold text-gray-200 mb-6">Cloud and DevOps</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-x-4 gap-y-8">
                <ResumeSkillCard skillName="AWS" image={AwsImg} />
                <ResumeSkillCard skillName="Azure" image={AzureImg} />
                <ResumeSkillCard skillName="Cloudflare" image={CloudflareImg} />
                <ResumeSkillCard skillName="Docker" image={DockerImg} />
            </div>
        </div>

        <div class="mt-12 mb-8">
            <h3 class="text-xl sm:text-2xl font-semibold text-gray-200 mb-6">Other Skills</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-x-4 gap-y-8">
                <ResumeSkillCard skillName="HTML5" image={Html5Img} />
                <ResumeSkillCard skillName="CSS3" image={Css3Img} />
                <ResumeSkillCard skillName="Git" image={GitImg} />
                <ResumeSkillCard skillName="Svelte" image={SvelteImg} />
            </div>
        </div>
    </section>
    <section class="my-8">
        <h1 class="max-w-7xl px-4 sm:px-6 lg:px-8 mt-12 sm:mt-16 lg:mt-20 mx-auto text-3xl sm:text-4xl font-extrabold text-white mb-4">Work Experience</h1>
        <ResumeTimeline />
    </section>
    </div>
    </div>
</DarkLayout>