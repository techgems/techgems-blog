---
import DarkLayout from "../layouts/DarkLayout.astro";
import GlassCard from "../components/GlassCard.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<DarkLayout 
	title={SITE_TITLE} 
	description={SITE_DESCRIPTION} 
	useWrapper={false}
	useBlogHead={false}
>
	<div class="relative overflow-hidden min-h-screen pt-16">
		<!-- Background blobs (full screen) -->
		<div class="absolute top-0 left-0 w-[500px] h-[500px] bg-indigo-700/30 rounded-full blur-[60px] animate-hero-blob"></div>
		<div class="absolute bottom-0 right-0 w-[550px] h-[550px] bg-cyan-600/25 rounded-full blur-[70px] animate-hero-blob animation-delay-3000"></div>
		<div class="absolute top-1/2 left-1/3 w-[400px] h-[400px] bg-teal-700/20 rounded-full blur-[60px] animate-hero-blob animation-delay-4000"></div>
		<div class="absolute top-1/4 right-1/4 w-[350px] h-[350px] bg-blue-600/20 rounded-full blur-[50px] animate-hero-blob animation-delay-2000"></div>
		<div class="absolute bottom-1/4 left-1/4 w-[450px] h-[450px] bg-sky-600/20 rounded-full blur-[65px] animate-hero-blob animation-delay-4000"></div>
		<div class="absolute top-3/4 right-1/3 w-[400px] h-[400px] bg-indigo-600/20 rounded-full blur-[55px] animate-hero-blob animation-delay-2000"></div>

		<div class="relative z-10 mx-auto mt-8 mb-20 max-w-7xl px-4 sm:px-6 lg:px-8">
			<section
				class="grid grid-cols-1 lg:grid-cols-2 gap-x-8 gap-y-12 lg:gap-y-16"
			>

			<!--Static Components-->
			<GlassCard title="Static Components">
				<Fragment slot="description">
					<p>
						Static Components (Formerly Razor Component Tag Helpers) is a minimalistic ASP.NET Core
						library that allows you to write UI components while
						maintaining compatibility with Razor Pages and MVC. This
						library will work for you if you're working on an MVC or
						Razor Pages only project and you wish to have better UI
						composition. It can be of help both in modernizing and
						organizing older projects as well as starting new ones where
						using a single page application framework is considered
						unnecessary due to lack of heavy UI interactions or simply
						familiarity with the MVC pattern.
					</p>
				</Fragment>
				<Fragment slot="stats">
					<div class="mt-6 flex items-center justify-center gap-4">
						<div class="text-center px-4 py-2 rounded-xl bg-white/5 border border-white/10 transition-all duration-300 hover:bg-white/15 hover:border-white/20 hover:scale-105 hover:shadow-[0_4px_20px_rgba(6,182,212,0.15)]">
							<p class="text-2xl font-bold text-cyan-400">45K+</p>
							<p class="text-xs text-gray-400 uppercase tracking-wide">NuGet Downloads</p>
							<p class="text-xs text-gray-400 uppercase tracking-wide">(counting the package's previous name)</p>
							
						</div>
					</div>
				</Fragment>
				<Fragment slot="links">
					<span class="cta-btn rounded-md text-white px-4 py-2 bg-neutral-800">
						<a href="https://github.com/techgems/static-components" target="_blank">GitHub</a>
					</span>
					<span class="cta-btn rounded-md text-white px-4 py-2 bg-neutral-800">
						<a href="https://static-components.techgems.net/" target="_blank">Docs</a>
					</span>
					<span class="cta-btn rounded-md text-white px-4 py-2 bg-neutral-800">
						<a href="https://www.nuget.org/packages/TechGems.StaticComponents" target="_blank">NuGet</a>
					</span>
				</Fragment>
			</GlassCard>

			<!--Vite.NET-->
			<GlassCard title="Vite.NET">
				<Fragment slot="description">
					<p class="mb-3">
						Vite.NET is a set of backend and front-end tools in order to
						easily integrate ASP.NET Core backends with Vite powered
						Single Page Applications.
					</p>
					<p>
						The library is comprised of two packages, a NuGet package
						for simple integration into .NET sites and an NPM package
						that contains a Vite plugin that reconfigures Vite defaults
						to play better with ASP.NET Core.
					</p>
				</Fragment>
				<Fragment slot="stats">
					<div class="mt-6 flex items-center justify-center gap-4">
						<div class="text-center px-4 py-2 rounded-xl bg-white/5 border border-white/10 transition-all duration-300 hover:bg-white/15 hover:border-white/20 hover:scale-105 hover:shadow-[0_4px_20px_rgba(6,182,212,0.15)]">
							<p class="text-2xl font-bold text-cyan-400">28K+</p>
							<p class="text-xs text-gray-400 uppercase tracking-wide">NuGet Downloads</p>
						</div>
						<div class="text-center px-4 py-2 rounded-xl bg-white/5 border border-white/10 transition-all duration-300 hover:bg-white/15 hover:border-white/20 hover:scale-105 hover:shadow-[0_4px_20px_rgba(6,182,212,0.15)]">
							<p class="text-2xl font-bold text-cyan-400">3.3K+</p>
							<p class="text-xs text-gray-400 uppercase tracking-wide">NPM Downloads</p>
						</div>
					</div>
				</Fragment>
				<Fragment slot="links">
					<span class="cta-btn rounded-md text-white px-4 py-2 bg-neutral-800">
						<a href="https://github.com/nickytonline/vite-dotnet" target="_blank">GitHub</a>
					</span>
					<span class="cta-btn rounded-md text-white px-4 py-2 bg-neutral-800">
						<a href="https://vite-dotnet.techgems.net/" target="_blank">Docs</a>
					</span>
					<span class="cta-btn rounded-md text-white px-4 py-2 bg-neutral-800">
						<a href="https://www.nuget.org/packages/Vite.NET" target="_blank">NuGet</a>
					</span>
					<span class="cta-btn rounded-md text-white px-4 py-2 bg-neutral-800">
						<a href="https://www.npmjs.com/package/vite-dotnet" target="_blank">NPM</a>
					</span>
				</Fragment>
			</GlassCard>



			<!--Windy UI-->
			<GlassCard title="Windy UI">
				<Fragment slot="description">
					<p>
						Windy UI is Tailwind UI based Blazor library. It is not
						meant to be a fully fledged component library, but rather, a
						starter for anyone to change and build their own custom
						Tailwind powered component library. Windy UI contains full
						support for Blazor form components and validations, as well
						as modals, icons, navigation, notifications and customizable
						color theming.
					</p>
				</Fragment>
				<Fragment slot="stats">
					<div class="mt-6 flex items-center justify-center gap-4">
						<div class="text-center px-4 py-2 rounded-xl bg-white/5 border border-white/10 transition-all duration-300 hover:bg-white/15 hover:border-white/20 hover:scale-105 hover:shadow-[0_4px_20px_rgba(6,182,212,0.15)]">
							<p class="text-2xl font-bold text-cyan-400">1.6K+</p>
							<p class="text-xs text-gray-400 uppercase tracking-wide">NuGet Downloads</p>
						</div>
					</div>
				</Fragment>
				<Fragment slot="links">
					<span class="cta-btn rounded-md text-white px-4 py-2 bg-neutral-800">
						<a href="https://github.com/techgems/windy-ui" target="_blank">GitHub</a>
					</span>
					<span class="cta-btn rounded-md text-white px-4 py-2 bg-neutral-800">
						<a href="https://windy-ui.techgems.net/" target="_blank">Docs</a>
					</span>
					<span class="cta-btn rounded-md text-white px-4 py-2 bg-neutral-800">
						<a href="https://www.nuget.org/packages/techgems.windyui" target="_blank">NuGet</a>
					</span>
				</Fragment>
			</GlassCard>
		</section>
		</div>
	</div>
</DarkLayout>
